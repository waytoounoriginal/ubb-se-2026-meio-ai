# dbdiagram.io — DBML Code

Copy-paste the code block below into [dbdiagram.io](https://dbdiagram.io/d) to render the diagram.

```sql
// ──────────────────────────────────────
// Movie & Personality Application Schema
// ──────────────────────────────────────

Table User {
  UserId int [pk, increment]
  Username varchar [not null]
  Email varchar [not null]
  PasswordHash varchar [not null]
  CreatedAt datetime [not null]
}

Table Movie {
  MovieId int [pk, increment]
  Title varchar [not null]
  PosterUrl varchar
  PrimaryGenre varchar
  Description varchar
  ReleaseYear int
  AverageRating float

  Note: 'External table — owned by the partner group. Read-only for this team.'
}

Table Reel {
  ReelId int [pk, increment]
  MovieId int [ref: > Movie.MovieId, note: 'nullable']
  CreatorUserId int [ref: > User.UserId, note: 'nullable — NULL for scraped reels']
  VideoUrl varchar [not null]
  ThumbnailUrl varchar
  Title varchar
  Caption varchar
  DurationSeconds int
  CropDataJson varchar [note: 'nullable — JSON {x, y, width, height}']
  BackgroundMusicId int [ref: > MusicTrack.MusicTrackId, note: 'nullable']
  Source varchar [not null, note: 'enum: upload | scraped']
  CreatedAt datetime [not null]
  LastEditedAt datetime

  Note: 'Shared table. Alex writes uploads, Andrei writes scraped trailers, Beatrice edits crop/music.'
}

Table MusicTrack {
  MusicTrackId int [pk, increment]
  TrackName varchar [not null]
  AudioUrl varchar [not null]
  DurationSeconds int

  Note: 'Lookup table for background music — owned by Beatrice.'
}

Table UserMoviePreference {
  UserMoviePreferenceId int [pk, increment]
  UserId int [ref: > User.UserId, not null]
  MovieId int [ref: > Movie.MovieId, not null]
  Score float [not null]
  LastModified datetime
  LastValueModification int

  indexes {
    (UserId, MovieId) [unique]
  }

  Note: 'Busiest shared table. Written by Bogdan (swipe), Gabi (tournament), Tudor (reel like). Read by Madi (matching).'
}

Table UserReelInteraction {
  InteractionId int [pk, increment]
  UserId int [ref: > User.UserId, not null]
  ReelId int [ref: > Reel.ReelId, not null]
  IsLiked boolean [default: false]
  WatchDurationSec int [note: 'nullable']
  WatchPercentage float [note: 'nullable']
  ViewedAt datetime [not null]

  indexes {
    (UserId, ReelId) [unique]
  }

  Note: 'One row per user per reel. Upserted on repeat views/likes — owned by Tudor.'
}

Table UserProfile {
  UserProfileId int [pk, increment]
  UserId int [ref: - User.UserId, unique, not null]
  TotalLikes int [default: 0]
  TotalWatchTimeSec bigint [default: 0]
  AvgWatchTimeSec float [default: 0]
  TotalClipsViewed int [default: 0]
  LikeToViewRatio float [default: 0]
  LastUpdated datetime

  Note: 'Cached engagement metrics — owned by Tudor, read by Madi for match details.'
}
```
