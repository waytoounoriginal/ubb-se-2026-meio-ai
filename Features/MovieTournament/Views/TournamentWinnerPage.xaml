<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.MovieTournament.Views.TournamentWinnerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Full-screen background poster -->
        <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.WinnerMovie.PosterUrl), Mode=OneWay}"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- Dark overlay -->
        <Border Background="#CC000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <!-- ScrollViewer wraps everything so the button is reachable on small windows -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,40,0,40">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="28">

                <TextBlock Text="🏆 ULTIMATE CHAMPION 🏆"
                           FontSize="42" FontWeight="Black" Foreground="Gold"
                           HorizontalAlignment="Center" />

                <Border CornerRadius="24" BorderBrush="Gold" BorderThickness="2"
                        Background="Black" HorizontalAlignment="Center" Padding="0">
                    <Grid Width="300" Height="420">
                        <Border CornerRadius="22" Background="Transparent">
                            <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.WinnerMovie.PosterUrl), Mode=OneWay}"
                                   Stretch="UniformToFill" Opacity="0.85" />
                        </Border>
                        <StackPanel VerticalAlignment="Bottom" Background="#E6000000"
                                    Padding="20" CornerRadius="0,0,22,22">
                            <TextBlock Text="{x:Bind ViewModel.WinnerMovie.Title, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold" Foreground="White"
                                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.WinnerMovie.ReleaseYear, Mode=OneWay}"
                                       FontSize="16" Foreground="LightGray"
                                       HorizontalAlignment="Center" Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Button stays close to the card -->
                <Button Content="Start Another Tournament"
                        Command="{x:Bind ViewModel.StartAnotherTournamentCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Padding="32,16" FontSize="18" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
