<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.MovieTournament.Views.TournamentMatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: back button + round label -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Button Content="Back to Creation"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    HorizontalAlignment="Left" VerticalAlignment="Center" />

            <TextBlock Text="{x:Bind ViewModel.RoundDisplay, Mode=OneWay}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="28" Foreground="Gold" FontWeight="SemiBold" />
        </Grid>

        <!-- First movie option vs second movie option -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- First movie option -->
            <Button Grid.Column="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Padding="0" CornerRadius="12"
                    Command="{x:Bind ViewModel.SelectMovieCommand}"
                    CommandParameter="{x:Bind ViewModel.MovieOptionA.MovieId, Mode=OneWay}"
                    PointerEntered="OnMoviePointerEntered"
                    PointerExited="OnMoviePointerExited"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>
                <Grid>
                    <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.MovieOptionA.PosterUrl), Mode=OneWay}"
                           Stretch="UniformToFill" />
                    <StackPanel VerticalAlignment="Bottom" Background="#B2000000" Padding="16">
                        <TextBlock Text="{x:Bind ViewModel.MovieOptionA.Title, Mode=OneWay}"
                                   FontSize="24" FontWeight="Bold" Foreground="White"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.MovieOptionA.ReleaseYear, Mode=OneWay}"
                                   HorizontalAlignment="Center" Foreground="LightGray" />
                    </StackPanel>
                </Grid>
            </Button>

            <TextBlock Grid.Column="1" Text="VS"
                       FontSize="32" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="32,0" />

            <!-- Second movie option -->
            <Button Grid.Column="2"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Padding="0" CornerRadius="12"
                    Command="{x:Bind ViewModel.SelectMovieCommand}"
                    CommandParameter="{x:Bind ViewModel.MovieOptionB.MovieId, Mode=OneWay}"
                    PointerEntered="OnMoviePointerEntered"
                    PointerExited="OnMoviePointerExited"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>
                <Grid>
                    <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.MovieOptionB.PosterUrl), Mode=OneWay}"
                           Stretch="UniformToFill" />
                    <StackPanel VerticalAlignment="Bottom" Background="#B2000000" Padding="16">
                        <TextBlock Text="{x:Bind ViewModel.MovieOptionB.Title, Mode=OneWay}"
                                   FontSize="24" FontWeight="Bold" Foreground="White"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.MovieOptionB.ReleaseYear, Mode=OneWay}"
                                   HorizontalAlignment="Center" Foreground="LightGray" />
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>