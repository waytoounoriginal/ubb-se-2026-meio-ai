<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.MovieTournament.Views.MovieTournamentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- STATE 0: SETUP VIEW -->
        <Grid Visibility="{x:Bind IsState(ViewModel.CurrentViewState, 0), Mode=OneWay}">
            <Grid Opacity="0.15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.Column="0" CornerRadius="16" Margin="4" Background="Transparent">
                    <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.Bg1), Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
                <Border Grid.Row="0" Grid.Column="1" CornerRadius="16" Margin="4" Background="Transparent">
                    <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.Bg2), Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
                <Border Grid.Row="1" Grid.Column="0" CornerRadius="16" Margin="4" Background="Transparent">
                    <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.Bg3), Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
                <Border Grid.Row="1" Grid.Column="1" CornerRadius="16" Margin="4" Background="Transparent">
                    <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.Bg4), Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
            </Grid>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MaxWidth="450" Background="#E6000000" Padding="40" CornerRadius="24" BorderBrush="#33FFFFFF" BorderThickness="1">
                <TextBlock Text="🏆 Movie Tournament Setup" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />

                <TextBlock Text="Select how many movies will compete:" HorizontalAlignment="Center" />

                <Slider Minimum="1" Maximum="{x:Bind ViewModel.MaxPoolSize, Mode=OneWay}" 
                        Value="{x:Bind ViewModel.PoolSize, Mode=TwoWay}" />

                <TextBlock Text="{x:Bind ViewModel.PoolSize, Mode=OneWay}" 
                           FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" />

                <TextBlock Text="{x:Bind ViewModel.SetupErrorMessage, Mode=OneWay}" 
                           Foreground="Red" HorizontalAlignment="Center"/>

                <Button Content="Start Tournament" 
                        Command="{x:Bind ViewModel.StartTournamentCommand}" 
                        Style="{StaticResource AccentButtonStyle}" 
                        HorizontalAlignment="Center" Padding="32,16" FontSize="18"/>
            </StackPanel>
        </Grid>

        <!-- STATE 1: MATCH VIEW -->
        <Grid Visibility="{x:Bind IsState(ViewModel.CurrentViewState, 1), Mode=OneWay}" Padding="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Button Content="Back to Creation" 
                        Command="{x:Bind ViewModel.ResetTournamentCommand}" HorizontalAlignment="Left" VerticalAlignment="Center" />

                <TextBlock Text="{x:Bind ViewModel.RoundDisplay, Mode=OneWay}" 
                           Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" Foreground="Gold" FontWeight="SemiBold" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Movie A -->
                <Button Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="0" CornerRadius="12"
                        Command="{x:Bind ViewModel.SelectMovieCommand}" CommandParameter="{x:Bind ViewModel.MovieOptionA.MovieId, Mode=OneWay}"
                        PointerEntered="MoviePointerEntered" PointerExited="MoviePointerExited" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <Grid>
                        <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.MovieOptionA.PosterUrl), Mode=OneWay}" Stretch="UniformToFill" />
                        <StackPanel VerticalAlignment="Bottom" Background="#B2000000" Padding="16">
                            <TextBlock Text="{x:Bind ViewModel.MovieOptionA.Title, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.MovieOptionA.ReleaseYear, Mode=OneWay}" HorizontalAlignment="Center" Foreground="LightGray" />
                        </StackPanel>
                    </Grid>
                </Button>

                <TextBlock Grid.Column="1" Text="VS" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" Margin="32,0" />

                <!-- Movie B -->
                <Button Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="0" CornerRadius="12"
                        Command="{x:Bind ViewModel.SelectMovieCommand}" CommandParameter="{x:Bind ViewModel.MovieOptionB.MovieId, Mode=OneWay}"
                        PointerEntered="MoviePointerEntered" PointerExited="MoviePointerExited" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <Grid>
                        <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.MovieOptionB.PosterUrl), Mode=OneWay}" Stretch="UniformToFill" />
                        <StackPanel VerticalAlignment="Bottom" Background="#B2000000" Padding="16">
                            <TextBlock Text="{x:Bind ViewModel.MovieOptionB.Title, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.MovieOptionB.ReleaseYear, Mode=OneWay}" HorizontalAlignment="Center" Foreground="LightGray" />
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>
        </Grid>

        <!-- STATE 2: WINNER VIEW -->
        <Grid Visibility="{x:Bind IsState(ViewModel.CurrentViewState, 2), Mode=OneWay}">
            <!-- Background Poster -->
            <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.WinnerMovie.PosterUrl), Mode=OneWay}" 
                   Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            
            <!-- Dark overlay for text readability -->
            <Border Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="32">
                <TextBlock Text="🏆 ULTIMATE CHAMPION 🏆" FontSize="42" FontWeight="Black" Foreground="Gold" HorizontalAlignment="Center" />

                <Border CornerRadius="24" BorderBrush="Gold" BorderThickness="2" Background="Black" HorizontalAlignment="Center" Padding="0">
                    <Grid Width="350" Height="500">
                        <Border CornerRadius="22" Background="Transparent">
                            <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.WinnerMovie.PosterUrl), Mode=OneWay}" Stretch="UniformToFill" Opacity="0.85" />
                        </Border>
                        <StackPanel VerticalAlignment="Bottom" Background="#E6000000" Padding="24" CornerRadius="0,0,22,22">
                            <TextBlock Text="{x:Bind ViewModel.WinnerMovie.Title, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.WinnerMovie.ReleaseYear, Mode=OneWay}" FontSize="18" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Content="Start Another Tournament" 
                        Command="{x:Bind ViewModel.ResetTournamentCommand}" 
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" Margin="0,12,0,0" Padding="32,16" FontSize="18"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
