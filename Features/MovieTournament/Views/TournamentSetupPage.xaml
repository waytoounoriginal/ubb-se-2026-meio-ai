<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.MovieTournament.Views.TournamentSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid>
        <!-- Faded background poster images -->
        <Grid Opacity="0.15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.Column="0" CornerRadius="16" Margin="4" Background="Transparent">
                <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.BackgroundPoster1), Mode=OneWay}" Stretch="UniformToFill" />
            </Border>
            <Border Grid.Row="0" Grid.Column="1" CornerRadius="16" Margin="4" Background="Transparent">
                <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.BackgroundPoster2), Mode=OneWay}" Stretch="UniformToFill" />
            </Border>
            <Border Grid.Row="1" Grid.Column="0" CornerRadius="16" Margin="4" Background="Transparent">
                <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.BackgroundPoster3), Mode=OneWay}" Stretch="UniformToFill" />
            </Border>
            <Border Grid.Row="1" Grid.Column="1" CornerRadius="16" Margin="4" Background="Transparent">
                <Image Source="{x:Bind ViewModel.GetImageSource(ViewModel.BackgroundPoster4), Mode=OneWay}" Stretch="UniformToFill" />
            </Border>
        </Grid>
        <!-- Setup card -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MaxWidth="450"
                    Background="#E6000000" Padding="40" CornerRadius="24"
                    BorderBrush="#33FFFFFF" BorderThickness="1">
            <TextBlock Text="🏆 Movie Tournament Setup"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Select how many movies will compete:"
                       HorizontalAlignment="Center" />
            <Slider Minimum="1" Maximum="{x:Bind ViewModel.MaxPoolSize, Mode=OneWay}"
                    Value="{x:Bind ViewModel.PoolSize, Mode=TwoWay}" />
            <TextBlock Text="{x:Bind ViewModel.PoolSize, Mode=OneWay}"
                       FontSize="32" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="White" />
            <TextBlock Text="{x:Bind ViewModel.SetupErrorMessage, Mode=OneWay}"
                       Foreground="Red" HorizontalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" />
            <Button Content="Start Tournament"
                    Command="{x:Bind ViewModel.StartTournamentCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center" Padding="32,16" FontSize="18" />
        </StackPanel>
    </Grid>
</Page>