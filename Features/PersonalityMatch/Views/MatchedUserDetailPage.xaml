<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.PersonalityMatch.Views.MatchedUserDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Back button + header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
            <Button Content="← Back" Click="BackButton_Click" />
            <TextBlock Text="{x:Bind ViewModel.MatchedUsername, Mode=OneWay}"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Loading -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Detail content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="600">

                <!-- Error message -->
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="Red" />

                <!-- Compatibility score -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Compatibility"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ProgressBar Value="{x:Bind ViewModel.MatchScore, Mode=OneWay}"
                                 Maximum="100"
                                 Height="12" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="{x:Bind ViewModel.MatchScore, Mode=OneWay}" />
                        <Run Text="% match" />
                    </TextBlock>
                </StackPanel>

                <!-- Facebook account -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Facebook"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.FacebookAccount, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />
                </StackPanel>

                <!-- Engagement stats -->
                <StackPanel Spacing="4"
                            Visibility="{x:Bind ViewModel.HasProfile, Mode=OneWay}">
                    <TextBlock Text="Engagement Stats"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,8,0,4" />

                    <Grid ColumnSpacing="24" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Likes" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.UserProfile.TotalLikes, Mode=OneWay}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Watch Time (s)" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.UserProfile.TotalWatchTimeSec, Mode=OneWay}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg Watch Time (s)" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.UserProfile.AvgWatchTimeSec, Mode=OneWay}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Clips Viewed" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.UserProfile.TotalClipsViewed, Mode=OneWay}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Like-to-View Ratio" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.UserProfile.LikeToViewRatio, Mode=OneWay}" />
                    </Grid>
                </StackPanel>

                <!-- Top preferences -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Top Movie Preferences"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,8,0,4" />

                    <ListView ItemsSource="{x:Bind ViewModel.TopPreferences, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               FontWeight="SemiBold">
                                        <Run Text="Movie #" />
                                        <Run Text="{Binding MovieId}" />
                                    </TextBlock>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Score:" />
                                        <TextBlock Text="{Binding Score}" FontWeight="Bold" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
