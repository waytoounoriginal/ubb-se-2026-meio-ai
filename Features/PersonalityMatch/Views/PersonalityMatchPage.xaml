<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.PersonalityMatch.Views.PersonalityMatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="Page_Loaded">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                   Margin="0,0,0,16" />

        <!-- Loading indicator -->
        <ProgressRing Grid.Row="2"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Match list -->
        <ListView Grid.Row="2"
                  x:Name="MatchListView"
                  ItemsSource="{x:Bind ViewModel.MatchResults, Mode=OneWay}"
                  Visibility="{x:Bind ViewModel.HasMatches, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="MatchListView_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MatchedUsername}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding FacebookAccount}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />
                        </StackPanel>

                        <ProgressBar Grid.Column="1"
                                     Value="{Binding MatchScore}"
                                     Maximum="100"
                                     VerticalAlignment="Center" />

                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding MatchScore}" />
                            <Run Text="%" />
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- No match fallback -->
        <StackPanel Grid.Row="2"
                    Visibility="{x:Bind ViewModel.ShowNoMatch, Mode=OneWay}"
                    Spacing="8">

            <TextBlock Text="No match"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,0,0,8" />

            <TextBlock Text="Maybe you like:"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="0,0,0,4" />

            <ListView ItemsSource="{x:Bind ViewModel.FallbackUsers, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="FallbackListView_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding MatchedUsername}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{Binding FacebookAccount}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />
                            </StackPanel>

                            <FontIcon Grid.Column="1"
                                      Glyph="&#xE76C;"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
