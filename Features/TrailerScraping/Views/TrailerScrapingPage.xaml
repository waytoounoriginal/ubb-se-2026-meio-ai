<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ubb_se_2026_meio_ai.Features.TrailerScraping.Views.TrailerScrapingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="DarkCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1E2E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
        </Style>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Page.Resources>

    <Grid Background="#0B0F1A" Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="1200">

                <!-- ═══ HEADER ═══ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Background="#0EA5E9" CornerRadius="8" Width="40" Height="40">
                            <FontIcon Glyph="&#xE774;" FontSize="18" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Trailer Scraper" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Admin Dashboard — Andrei" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#22C55E"/>
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Foreground="#94A3B8" FontSize="14"/>
                    </StackPanel>
                </Grid>

                <!-- ═══ STATS BAR ═══ -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <FontIcon Glyph="&#xE8A4;" Foreground="#0EA5E9" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalMovies, Mode=OneWay}" Style="{StaticResource StatNumberStyle}"/>
                            <TextBlock Text="Movies in DB" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <FontIcon Glyph="&#xE714;" Foreground="#A855F7" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalReels, Mode=OneWay}" Style="{StaticResource StatNumberStyle}"/>
                            <TextBlock Text="Total Reels" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <FontIcon Glyph="&#xE9D5;" Foreground="#06B6D4" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalJobs, Mode=OneWay}" Style="{StaticResource StatNumberStyle}"/>
                            <TextBlock Text="Total Jobs" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <FontIcon Glyph="&#xE768;" Foreground="#F59E0B" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Bind ViewModel.RunningJobs, Mode=OneWay}" Style="{StaticResource StatNumberStyle}"/>
                            <TextBlock Text="Running" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <FontIcon Glyph="&#xE73E;" Foreground="#22C55E" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Bind ViewModel.CompletedJobs, Mode=OneWay}" Style="{StaticResource StatNumberStyle}"/>
                            <TextBlock Text="Completed" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <FontIcon Glyph="&#xEA39;" Foreground="#EF4444" FontSize="18" Margin="0,0,0,8"/>
                            <TextBlock Text="{x:Bind ViewModel.FailedJobs, Mode=OneWay}" Style="{StaticResource StatNumberStyle}"/>
                            <TextBlock Text="Failed" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ SCRAPER CARD ═══ -->
                <Border Style="{StaticResource DarkCardStyle}" BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel Spacing="16">

                        <!-- Title row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="Scrape Trailers for a Movie" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                <Border Background="#065F46" CornerRadius="4" Padding="8,2">
                                    <TextBlock Text="SCRAPER" Foreground="#34D399" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}" Background="Transparent"
                                    BorderBrush="#334155" CornerRadius="8" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="#94A3B8"/>
                                    <TextBlock Text="Refresh" Foreground="#94A3B8" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Foreground="#64748B" FontSize="12" TextWrapping="Wrap"
                                   Text="Type a movie name from the database below — matching movies will appear in a dropdown. Select a movie, then click Start Scrape to find YouTube trailers and download them as MP4 reels."/>

                        <!-- Movie search label -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Movie Name" Foreground="#94A3B8" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="— type to search movies in the database (case-insensitive)" Foreground="#475569" FontSize="12"/>
                            </StackPanel>

                            <!-- Search row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- AutoSuggestBox for movie lookup -->
                                <AutoSuggestBox x:Name="MovieSearchBox"
                                                Grid.Column="0"
                                                PlaceholderText="e.g. Batman, Dune, Inception..."
                                                TextChanged="MovieSearchBox_TextChanged"
                                                SuggestionChosen="MovieSearchBox_SuggestionChosen"
                                                QuerySubmitted="MovieSearchBox_QuerySubmitted"
                                                QueryIcon="Find"
                                                Margin="0,0,8,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="Max results" Foreground="#94A3B8" VerticalAlignment="Center" FontSize="13"/>
                                    <ComboBox x:Name="MaxResultsCombo"
                                              Background="#111827" Foreground="White" BorderBrush="#334155"
                                              CornerRadius="8" MinWidth="70"/>
                                </StackPanel>

                                <Button Grid.Column="2" Command="{x:Bind ViewModel.StartScrapeCommand}"
                                        Background="#0EA5E9" Foreground="White" CornerRadius="8" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="White"/>
                                        <TextBlock Text="Start Scrape" FontWeight="SemiBold" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Selected movie info / warning -->
                            <StackPanel>
                                <!-- Show selected movie -->
                                <Border x:Name="SelectedMovieCard" Visibility="Collapsed"
                                        Background="#0D1117" CornerRadius="8" Padding="12,8" Margin="0,8,0,0"
                                        BorderBrush="#22C55E" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE73E;" Foreground="#22C55E" FontSize="16"/>
                                        <TextBlock x:Name="SelectedMovieText" Foreground="#22C55E" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Warning: no match found -->
                                <Border x:Name="NoMatchWarning" Visibility="Collapsed"
                                        Background="#1C1917" CornerRadius="8" Padding="12,8" Margin="0,8,0,0"
                                        BorderBrush="#F59E0B" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE7BA;" Foreground="#F59E0B" FontSize="16"/>
                                        <TextBlock Text="No matching movie found in the database. Try a different name."
                                                   Foreground="#F59E0B" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- What this does -->
                        <Border Background="#0D1117" CornerRadius="8" Padding="16,12" BorderBrush="#1E293B" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="WHAT THIS DOES" Foreground="#475569" FontSize="11" FontWeight="Bold" CharacterSpacing="80"/>
                                <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,6,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#164E63" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="01" Foreground="#22D3EE" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Select Movie" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Pick an existing movie from the database via autocomplete" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#164E63" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="02" Foreground="#22D3EE" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Search YouTube" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Finds trailers for that movie via YouTube Data API v3" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#164E63" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="03" Foreground="#22D3EE" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Download &amp; Create Reels" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Downloads as MP4 (max 60s), inserts into Reel table with MovieId FK" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ LOGS PANEL ═══ -->
                <Border Style="{StaticResource DarkCardStyle}" BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Scrape Logs" FontSize="16" FontWeight="SemiBold" Foreground="White"/>

                        <ListView ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                                  MaxHeight="300" SelectionMode="None"
                                  Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,6" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="4" Padding="8,2" MinWidth="50" HorizontalAlignment="Center"
                                                Background="#1E293B">
                                            <TextBlock Text="{Binding Level}" FontSize="11" FontWeight="Bold"
                                                       Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="1" Text="{Binding Timestamp}" FontSize="11"
                                                   Foreground="#475569" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12"
                                                   Foreground="#CBD5E1" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="EmptyLogsText" Text="No log entries yet. Start a scrape job to see logs here."
                                   Foreground="#475569" FontSize="12" FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- ═══ MOVIE TABLE VIEWER ═══ -->
                <Border Style="{StaticResource DarkCardStyle}" BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8A4;" Foreground="#0EA5E9" FontSize="16"/>
                            <TextBlock Text="Movie Table" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <Border Background="#1E293B" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.TotalMovies, Mode=OneWay}" Foreground="#94A3B8" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <!-- Column headers -->
                        <Grid Padding="4,6" ColumnSpacing="8" Background="#111827" CornerRadius="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ID" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="Title" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Genre" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="Year" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                        </Grid>

                        <ListView ItemsSource="{x:Bind ViewModel.MovieTableItems, Mode=OneWay}"
                                  MaxHeight="250" SelectionMode="None" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding MovieId}" Foreground="#94A3B8" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="2" Background="#1E293B" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Genre}" Foreground="#A855F7" FontSize="11"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding ReleaseYear}" Foreground="#94A3B8" FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- ═══ REEL TABLE VIEWER ═══ -->
                <Border Style="{StaticResource DarkCardStyle}" BorderBrush="#1E293B" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE714;" Foreground="#A855F7" FontSize="16"/>
                            <TextBlock Text="Reel Table" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <Border Background="#1E293B" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.TotalReels, Mode=OneWay}" Foreground="#94A3B8" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <!-- Column headers -->
                        <Grid Padding="4,6" ColumnSpacing="8" Background="#111827" CornerRadius="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ID" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="MovieId" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Title" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="Source" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="VideoUrl" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Grid.Column="5" Text="Created" Foreground="#64748B" FontSize="11" FontWeight="Bold"/>
                        </Grid>

                        <ListView ItemsSource="{x:Bind ViewModel.ReelTableItems, Mode=OneWay}"
                                  MaxHeight="300" SelectionMode="None" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ReelId}" Foreground="#94A3B8" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="{Binding MovieId}" Foreground="#0EA5E9" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Title}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="3" Background="#065F46" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Source}" Foreground="#34D399" FontSize="11"/>
                                        </Border>
                                        <TextBlock Grid.Column="4" Text="{Binding VideoUrl}" Foreground="#64748B" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="5" Text="{Binding CreatedAt}" Foreground="#475569" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="EmptyReelsText" Text="No reels yet. Scrape some trailers to populate this table."
                                   Foreground="#475569" FontSize="12" FontStyle="Italic"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
